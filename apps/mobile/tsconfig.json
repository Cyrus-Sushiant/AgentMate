{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      // react-native-webrtc's typings import 'event-target-shim/index', a
      // subpath its exports map doesn't expose under moduleResolution:bundler.
      "event-target-shim/index": ["./node_modules/event-target-shim/index.d.ts"]
    }
  }
}
